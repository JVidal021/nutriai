{
  "expo": {
    "name": "NutriAI",
    "slug": "nutriai",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nutriai.app",
      "buildNumber": "4",
      "infoPlist": {
        "NSCameraUsageDescription": "O NutriAI usa a câmera para fotografar seus pratos e analisar as calorias.",
        "NSPhotoLibraryUsageDescription": "O NutriAI acessa sua galeria para analisar fotos de refeições."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.nutriai.app",
      "versionCode": 4,
      "jsEngine": "hermes",
      "softwareKeyboardLayoutMode": "resize",
      "blockedPermissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.READ_CALL_LOG",
        "android.permission.READ_SMS",
        "android.permission.RECEIVE_SMS"
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "O NutriAI precisa da câmera para fotografar seus pratos."
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-localization",
      "expo-updates",
      [
        "@sentry/react-native/expo",
        {
          "organization": "nutriai-pz",
          "project": "react-native"
        }
      ]
    ],
    "scheme": "nutriai",
    "newArchEnabled": true,
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/96e4cfe4-5f9d-4f3a-9f1c-037c8812eb01",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "96e4cfe4-5f9d-4f3a-9f1c-037c8812eb01"
      }
    },
    "owner": "jimmyvidal"
  }
}
